# Copy this file to .env and fill in the values for your Jetson host.
# scripts/deploy_to_jetson.sh and similar helpers source these on startup.

# SSH user on the Jetson (default: jetson)
JETSON_USER=jetson

# IP or hostname of the Jetson on your network
JETSON_HOST=192.168.1.100

# Absolute path on the Jetson where this repo lives (rsync target)
JETSON_PATH=/home/jetson/projects/aquascope

# Password for the JETSON_USER account (used by sshpass-based scripts)
JETSON_PASSWORD=changeme
